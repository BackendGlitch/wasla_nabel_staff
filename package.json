{
  "name": "wasla-nabel-staff",
  "private": true,
  "version": "1.18.0",
  "description": "Wasla Staff Desktop Application",
  "author": {
    "name": "STE Dhraiff Services Transport",
    "email": "info@wasla.tn"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:win",
    "build:web": "tsc && vite build",
    "build:win-unpacked": "tsc && vite build && electron-builder --win --x64 --dir",
    "build:publish": "tsc && vite build && electron-builder --publish always --win --x64",
    "build:win": "tsc && vite build && electron-builder --win --x64",
    "build:linux": "tsc && vite build && electron-builder --linux --x64",
    "test:winusb-print": "node scripts/test-winusb-escpos.cjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.545.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serialport": "^12.0.0",
    "escpos": "3.0.0-alpha.6",
    "escpos-usb": "3.0.0-alpha.4",
    "usb": "^2.14.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.21",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:BackendGlitch/wasla_nabel_staff.git"
  }
}
